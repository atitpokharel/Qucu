#!/usr/bin/env bash
#PBS -N qucu_simulation
#PBS -q classgpu
#PBS -l select=1:gpuname=ampere:ngpus=1:ncpus=1:mpiprocs=1:mem=8000mb
#PBS -l walltime=01:00:00
#PBS -j oe
#PBS -o qucu_simulation.qsub_out

cd "$PBS_O_WORKDIR" || exit 1

module load cuda && \
  make clean && \
  make all && \
  make run && \
  make plot
